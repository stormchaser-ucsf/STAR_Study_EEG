b=b(:,idx_imag)';
a=double(a);
b=double(b);

% a=a-mean(a,2);
% b=b-mean(b,2);

[c1,s1,l1] = pca(a,'Centered','on');
[c2,s2,l2] = pca(b,'Centered','on');


