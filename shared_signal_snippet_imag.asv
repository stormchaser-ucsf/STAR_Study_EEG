%Q2: what are the principal angles betwen the two manifolds? More sig. than
%TME stats?
dim=11;
cd('/home/user/Documents/Repositories/STAR_Study_EEG')
addpath(genpath(pwd))
addpath(genpath('/home/user/Documents/Repositories/ECoG_BCI_TravelingWaves/'))
